@model LoginDemo.Models.LoginViewModel
@{
    ViewData["Title"] = "Log in";
    var usernameInvalid = ViewData.ModelState["Username"]?.Errors.Count > 0;
    var passwordInvalid = ViewData.ModelState["Password"]?.Errors.Count > 0;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Log in</h2>

        <form asp-controller="Account" asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" aria-live="assertive"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username"
                       class="form-control"
                       autofocus
                       autocomplete="username"
                       aria-describedby="Username-validation"
                       aria-invalid="@usernameInvalid.ToString().ToLowerInvariant()" />
                <span asp-validation-for="Username" id="Username-validation" class="text-danger" role="alert" aria-live="polite"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password"
                       class="form-control"
                       autocomplete="current-password"
                       aria-describedby="Password-validation"
                       aria-invalid="@passwordInvalid.ToString().ToLowerInvariant()" />
                <span asp-validation-for="Password" id="Password-validation" class="text-danger" role="alert" aria-live="polite"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">Log in</button>

            <div class="mt-3">
                <a asp-controller="Account" asp-action="ForgotPassword">Forgot your password?</a>
            </div>
        </form>

        <hr />
        <p class="text-muted small">
            Demo accounts: <code>admin / Admin@123</code> or <code>demo / Demo@123</code>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
