@model LoginDemo.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
    var emailInvalid = ViewData.ModelState["Email"]?.Errors.Count > 0;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-3">Forgot your password?</h2>
        <p class="text-muted">Enter your account email and we'll show you a reset link.</p>

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" aria-live="assertive"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email"
                       class="form-control"
                       autofocus
                       autocomplete="email"
                       aria-describedby="Email-validation"
                       aria-invalid="@emailInvalid.ToString().ToLowerInvariant()" />
                <span asp-validation-for="Email" id="Email-validation" class="text-danger" role="alert" aria-live="polite"></span>
            </div>

            <button type="submit" class="btn btn-primary">Send reset link</button>
            <a asp-controller="Account" asp-action="Login" class="btn btn-link">Back to log in</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
