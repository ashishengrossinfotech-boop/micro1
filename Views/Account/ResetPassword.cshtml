@model LoginDemo.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
    var newPasswordInvalid = ViewData.ModelState["NewPassword"]?.Errors.Count > 0;
    var confirmPasswordInvalid = ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0;
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-3">Reset your password</h2>

        <form asp-controller="Account" asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" aria-live="assertive"></div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword"
                       class="form-control"
                       autofocus
                       autocomplete="new-password"
                       aria-describedby="NewPassword-validation"
                       aria-invalid="@newPasswordInvalid.ToString().ToLowerInvariant()" />
                <span asp-validation-for="NewPassword" id="NewPassword-validation" class="text-danger" role="alert" aria-live="polite"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword"
                       class="form-control"
                       autocomplete="new-password"
                       aria-describedby="ConfirmPassword-validation"
                       aria-invalid="@confirmPasswordInvalid.ToString().ToLowerInvariant()" />
                <span asp-validation-for="ConfirmPassword" id="ConfirmPassword-validation" class="text-danger" role="alert" aria-live="polite"></span>
            </div>

            <button type="submit" class="btn btn-primary">Reset password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
