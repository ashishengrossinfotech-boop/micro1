@{
    ViewData["Title"] = "Check your email";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-3">Check your email</h2>
        <p>If an account exists for that email address, instructions to reset the password have been sent.</p>

        @if (ViewBag.ResetLink is not null)
        {
            <div class="alert alert-info">
                <strong>Demo mode:</strong> no email server is configured, so here's the reset link directly:<br />
                <a href="@ViewBag.ResetLink">@ViewBag.ResetLink</a>
            </div>
        }

        <a asp-controller="Account" asp-action="Login" class="btn btn-link">Back to log in</a>
    </div>
</div>
